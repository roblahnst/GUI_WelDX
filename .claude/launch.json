{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "weldx-editor",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": [
        "run",
        "weldx_editor/app.py",
        "--server.headless=true",
        "--theme.base=dark",
        "--theme.primaryColor=#4f8ef7",
        "--theme.backgroundColor=#0f1117",
        "--theme.secondaryBackgroundColor=#1a1d27",
        "--theme.textColor=#e2e8f0",
        "--browser.gatherUsageStats=false"
      ],
      "port": 8501
    }
  ]
}
